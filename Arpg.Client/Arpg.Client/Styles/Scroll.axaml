<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Minimalist ScrollViewer Style -->
    <Style Selector="ScrollViewer.Minimal">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="HorizontalScrollBarVisibility" Value="Disabled"/>
        <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
    </Style>

    <!-- Global ScrollBar Customization for the Minimal class -->
    <Style Selector="ScrollViewer.Minimal /template/ ScrollBar">
        <Setter Property="AllowAutoHide" Value="True"/>
    </Style>

    <Style Selector="ScrollViewer.Minimal /template/ ScrollBar#PART_VerticalScrollBar">
        <Setter Property="Width" Value="8"/>
        <Setter Property="Background" Value="Transparent"/>
    </Style>

    <!-- Customizing the Thumb (the draggable part) -->
    <Style Selector="ScrollViewer.Minimal /template/ ScrollBar#PART_VerticalScrollBar /template/ Thumb">
        <Setter Property="Background" Value="{StaticResource ThirdPlate}"/>
        <Setter Property="Opacity" Value="0.4"/>
        <Setter Property="CornerRadius" Value="4"/>
        <Setter Property="Width" Value="4"/>
        <Setter Property="HorizontalAlignment" Value="Right"/>
        <Setter Property="Margin" Value="0,0,2,0"/>
        <Setter Property="Template">
            <ControlTemplate>
                <Border Background="{TemplateBinding Background}"
                        CornerRadius="{TemplateBinding CornerRadius}"
                        Width="{TemplateBinding Width}"
                        Opacity="{TemplateBinding Opacity}">
                    <Border.Transitions>
                        <Transitions>
                            <DoubleTransition Property="Opacity" Duration="0:0:0.2"/>
                            <DoubleTransition Property="Width" Duration="0:0:0.2"/>
                        </Transitions>
                    </Border.Transitions>
                </Border>
            </ControlTemplate>
        </Setter>
    </Style>

    <!-- Hover effect on Thumb -->
    <Style Selector="ScrollViewer.Minimal /template/ ScrollBar#PART_VerticalScrollBar /template/ Thumb:pointerover">
        <Setter Property="Opacity" Value="0.8"/>
        <Setter Property="Background" Value="{StaticResource SecondElement}"/>
        <Setter Property="Width" Value="6"/>
    </Style>

    <!-- Remove buttons from ScrollBar -->
    <Style Selector="ScrollViewer.Minimal /template/ ScrollBar#PART_VerticalScrollBar /template/ RepeatButton">
        <Setter Property="IsVisible" Value="False"/>
    </Style>

</Styles>
