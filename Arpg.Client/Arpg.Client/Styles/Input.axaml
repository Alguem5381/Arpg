<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:Arpg.Client.Controls">

    <!-- AuthTextBox -->
    <Style Selector="controls|AnimatedTextBox">
        <Setter Property="ErrorForeground" Value="{StaticResource FirstWarning}"/>
        <Setter Property="OutsideBorderThickness" Value="0"/>
        <Setter Property="OutsideCornerRadius" Value="10"/>
        <Setter Property="OutsideBackground" Value="{StaticResource FirstElement}"/>
        <Setter Property="OutsidePadding" Value="10"/>
        <Setter Property="WatermarkForeground" Value="{StaticResource ThirdText}"/>
        <Setter Property="Background" Value="{StaticResource SecondElement}"/>
        <Setter Property="Foreground" Value="{StaticResource SecondText}"/>
        <Setter Property="CornerRadius" Value="10"/>
        <Setter Property="Padding" Value="10"/>
        <Setter Property="FocusAdorner" Value="{x:Null}"/>
        <Setter Property="RenderTransformOrigin" Value="50%,50%"/>
        <Setter Property="BackgroundOnHover" Value="{StaticResource FirstPlate}"/>
        <Setter Property="SelectionBrush" Value="{StaticResource SelectionPlate}"/>
        <Setter Property="SelectionForegroundBrush" Value="{StaticResource SecondText}"/>
        <Setter Property="Template">
            <ControlTemplate>
            <Grid MaxHeight="{TemplateBinding InternalMaxHeight}"
                  ClipToBounds="True">
                <Grid.Transitions>
                    <Transitions>
                        <DoubleTransition Property="MaxHeight" Duration="0:0:1.0" Easing="QuarticEaseInOut"/>
                    </Transitions>
                </Grid.Transitions>
                <!-- Stable Hit-Test Border -->
                <Border Background="Transparent"
                        Margin="0,0,0,10"
                        CornerRadius="{TemplateBinding OutsideCornerRadius}">
                    <Border Name="PART_OuterBorder"
                            Background="{TemplateBinding OutsideBackground}"
                            CornerRadius="{TemplateBinding OutsideCornerRadius}"
                            BorderBrush="{TemplateBinding OutsideBorderBrush}"
                            BorderThickness="{TemplateBinding OutsideBorderThickness}"
                            Padding="{TemplateBinding OutsidePadding}"
                            Opacity="{TemplateBinding InternalOpacity}"
                            ClipToBounds="True">
                        <Border.Transitions>
                            <Transitions>
                                <DoubleTransition Property="Opacity" Duration="0:0:0.5" Easing="CubicEaseInOut"/>
                                <BrushTransition Property="Background" Duration="0:0:0.2"/>
                                <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.1" Easing="CubicEaseOut"/>
                            </Transitions>
                        </Border.Transitions>
                        
                        <Grid RowDefinitions="Auto, Auto">
                                <Border Grid.Row="0"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="{TemplateBinding CornerRadius}"
                                    Padding="{TemplateBinding Padding}"
                                    Opacity="{TemplateBinding InternalOpacity}">
                                <Border.Transitions>
                                    <Transitions>
                                        <DoubleTransition Property="Opacity" Duration="0:0:0.25" Easing="CubicEaseInOut"/>
                                    </Transitions>
                                </Border.Transitions>
                                <Panel>
                                    <TextBlock Name="PART_Watermark"
                                               Text="{TemplateBinding Watermark}"
                                               Foreground="{TemplateBinding WatermarkForeground}"
                                               IsVisible="{TemplateBinding Text, Converter={x:Static StringConverters.IsNullOrEmpty}}"
                                               VerticalAlignment="Center"
                                               HorizontalAlignment="Left"
                                               Opacity="0.7"/>
                                    <ScrollViewer Name="PART_ScrollViewer"
                                                  HorizontalScrollBarVisibility="Hidden"
                                                  VerticalScrollBarVisibility="Hidden">
                                        <TextPresenter Name="PART_TextPresenter"
                                                       Text="{TemplateBinding Text, Mode=TwoWay}"
                                                       CaretIndex="{TemplateBinding CaretIndex}"
                                                       SelectionStart="{TemplateBinding SelectionStart}"
                                                       SelectionEnd="{TemplateBinding SelectionEnd}"
                                                       CaretBrush="{TemplateBinding Foreground}"
                                                       TextWrapping="NoWrap"
                                                       PasswordChar="{TemplateBinding PasswordChar}"
                                                       SelectionBrush="{TemplateBinding SelectionBrush}"
                                                       SelectionForegroundBrush="{TemplateBinding SelectionForegroundBrush}"
                                                       VerticalAlignment="Center"/>
                                    </ScrollViewer>
                                </Panel>
                            </Border>

                            <Border Name="PART_ErrorContainer"
                                    Grid.Row="1"
                                    ClipToBounds="True"
                                    MaxHeight="{TemplateBinding InternalErrorHeight}"
                                    Opacity="{TemplateBinding InternalErrorOpacity}">
                                <Border.Transitions>
                                    <Transitions>
                                        <DoubleTransition Property="MaxHeight" Duration="0:0:0.3" Easing="CubicEaseInOut"/>
                                        <DoubleTransition Property="Opacity" Duration="0:0:0.2" Easing="CubicEaseInOut"/>
                                    </Transitions>
                                </Border.Transitions>

                                <TextBlock Text="{TemplateBinding InternalErrorText}"
                                           Foreground="{TemplateBinding ErrorForeground}"
                                           FontSize="12"
                                           Margin="5,6,0,0"
                                           TextWrapping="Wrap">
                                </TextBlock>
                            </Border>
                        </Grid>
                    </Border>
                </Border>
            </Grid>
        </ControlTemplate>
    </Setter>
</Style>

    <Style Selector="controls|AnimatedTextBox:pointerover,
                   controls|AnimatedTextBox:focus-within">
        <Setter Property="OutsideBackground" Value="{Binding BackgroundOnHover, RelativeSource={RelativeSource Self}}"/>
    </Style>
    
    <Style Selector="controls|AnimatedTextBox:pointerover /template/ Border#PART_OuterBorder,
                   controls|AnimatedTextBox:focus-within /template/ Border#PART_OuterBorder">
        <Setter Property="RenderTransform" Value="scale(0.98)"/>
    </Style>

                    <!-- RevealToggleButton Style -->
    <Style Selector="ToggleButton.RevealToggle">
        <Setter Property="Background" Value="{StaticResource FirstElement}"/>
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="Padding" Value="0,5,0,0"/>
        <Setter Property="Width" Value="35"/>
        <Setter Property="Height" Value="35"/>
        <Setter Property="CornerRadius" Value="10"/>
        <Setter Property="FocusAdorner" Value="{x:Null}"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Template">
            <ControlTemplate>
                <!-- Outer transparent border: captura o hover na borda, evita flickering -->
                <Border Background="Transparent"
                        CornerRadius="{TemplateBinding CornerRadius}"
                        Width="{TemplateBinding Width}"
                        Height="{TemplateBinding Height}">
                    <!-- Inner named border: recebe o scale transform -->
                    <Border Name="PART_OuterBorder"
                            Background="{TemplateBinding Background}"
                            CornerRadius="{TemplateBinding CornerRadius}"
                            Padding="{TemplateBinding Padding}">
                        <Border.Transitions>
                            <Transitions>
                                <BrushTransition Property="Background" Duration="0:0:0.2"/>
                                <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.1" Easing="CubicEaseOut"/>
                            </Transitions>
                        </Border.Transitions>
                        <Panel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <!-- Olho sempre visível -->
                            <Path Data="M12 4.5C7 4.5 2.73 7.61 1 12c1.73 4.39 6 7.5 11 7.5s9.27-3.11 11-7.5c-1.73-4.39-6-7.5-11-7.5zM12 17c-2.76 0-5-2.24-5-5s2.24-5 5-5 5 2.24 5 5-2.24 5-5 5zm0-8c-1.66 0-3 1.34-3 3s1.34 3 3 3 3-1.34 3-3-1.34-3-3-3z"
                                    Fill="{TemplateBinding Foreground}"
                                    Stretch="Uniform"
                                    Width="20"
                                    Height="20"/>
                            <!-- Linha de corte: mesma cor do fundo, mais grossa, cria efeito de separação no olho -->
                            <Path Name="PART_CutLine"
                                    Data="M 4 4 L 20 15"
                                    Stroke="{TemplateBinding Background}"
                                    StrokeThickness="4"
                                    StrokeLineCap="Round"
                                    StrokeDashArray="20"
                                    StrokeDashOffset="20"
                                    Stretch="Uniform"
                                    Width="20"
                                    Height="20">
                                <Path.Transitions>
                                    <Transitions>
                                        <DoubleTransition Property="StrokeDashOffset" Duration="0:0:0.35" Easing="CubicEaseInOut"/>
                                    </Transitions>
                                </Path.Transitions>
                            </Path>
                            <!-- Linha branca principal por cima -->
                            <Path Name="PART_SlashLine"
                                    Data="M 4 4 L 20 15"
                                    Stroke="{TemplateBinding Foreground}"
                                    StrokeThickness="2"
                                    StrokeLineCap="Round"
                                    StrokeDashArray="20"
                                    StrokeDashOffset="20"
                                    Stretch="Uniform"
                                    Width="20"
                                    Height="20">
                                <Path.Transitions>
                                    <Transitions>
                                        <DoubleTransition Property="StrokeDashOffset" Duration="0:0:0.35" Easing="CubicEaseInOut"/>
                                    </Transitions>
                                </Path.Transitions>
                            </Path>
                        </Panel>
                    </Border>
                </Border>
            </ControlTemplate>
        </Setter>
    </Style>

    <Style Selector="ToggleButton.RevealToggle:pointerover,
                   ToggleButton.RevealToggle:pressed,
                   ToggleButton.RevealToggle:checked">
        <Setter Property="Background" Value="{StaticResource FirstPlate}"/>
    </Style>
    <Style Selector="ToggleButton.RevealToggle:pointerover /template/ Border#PART_OuterBorder,
                   ToggleButton.RevealToggle:pressed /template/ Border#PART_OuterBorder,
                   ToggleButton.RevealToggle:checked /template/ Border#PART_OuterBorder">
        <Setter Property="RenderTransform" Value="scale(0.9)"/>
    </Style>

    <!-- Focus indicator for ToggleButton -->
    <Style Selector="ToggleButton.RevealToggle:focus-visible /template/ Border#PART_OuterBorder">
        <Setter Property="BorderBrush" Value="{StaticResource ThirdPlate}"/>
        <Setter Property="BorderThickness" Value="1"/>
    </Style>
    <!-- Linha aparece (se desenha) quando o botão está ativo (IsChecked) -->
    <Style Selector="ToggleButton.RevealToggle:checked /template/ Path#PART_SlashLine,
                   ToggleButton.RevealToggle:checked /template/ Path#PART_CutLine">
        <Setter Property="StrokeDashOffset" Value="0"/>
    </Style>
    
    <!-- AnimatedCodeBox -->
    <Style Selector="controls|AnimatedCodeBox">
        <Setter Property="ErrorForeground" Value="{StaticResource FirstWarning}"/>
        <Setter Property="Background" Value="{StaticResource SecondElement}"/>
        <Setter Property="Foreground" Value="{StaticResource SecondText}"/>
        <Setter Property="CornerRadius" Value="10"/>
        <Setter Property="Padding" Value="15,20,15,20"/>
        <Setter Property="FontSize" Value="24"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="LetterSpacing" Value="12"/>
        <Setter Property="TextAlignment" Value="Center"/>
        <Setter Property="FocusAdorner" Value="{x:Null}"/>
        <Setter Property="RenderTransformOrigin" Value="50%,50%"/>
        <Setter Property="SelectionBrush" Value="{StaticResource SelectionPlate}"/>
        <Setter Property="SelectionForegroundBrush" Value="{StaticResource SecondText}"/>
        <Setter Property="Transitions">
            <Transitions>
                <ThicknessTransition Property="Margin" Duration="0:0:0.4" Easing="CubicEaseInOut"/>
                <DoubleTransition Property="Opacity" Duration="0:0:0.5" Easing="CubicEaseInOut"/>
                <BrushTransition Property="Background" Duration="0:0:0.2"/>
                <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.1" Easing="CubicEaseOut"/>
            </Transitions>
        </Setter>
        <Style Selector="^:pointerover /template/ Border#PART_OuterBorder">
            <Setter Property="RenderTransform" Value="scale(0.98)"/>
        </Style>
        <Setter Property="Template">
            <ControlTemplate>
                <!-- Root container with MaxHeight transition -->
                <Grid MaxHeight="{TemplateBinding InternalMaxHeight}"
                      ClipToBounds="True">
                    <Grid.Transitions>
                        <Transitions>
                            <DoubleTransition Property="MaxHeight" Duration="0:0:1.0" Easing="QuarticEaseInOut"/>
                        </Transitions>
                    </Grid.Transitions>
                    
                    <Border Background="Transparent"
                            CornerRadius="{TemplateBinding CornerRadius}">
                        <Grid RowDefinitions="Auto, Auto">
                            <Border Name="PART_OuterBorder"
                                    Grid.Row="0"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="{TemplateBinding CornerRadius}"
                                    Padding="{TemplateBinding Padding}"
                                    Opacity="{TemplateBinding InternalOpacity}">
                                <Border.Transitions>
                                    <Transitions>
                                        <DoubleTransition Property="Opacity" Duration="0:0:0.5" Easing="CubicEaseInOut"/>
                                        <BrushTransition Property="Background" Duration="0:0:0.2"/>
                                        <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.1" Easing="CubicEaseOut"/>
                                    </Transitions>
                                </Border.Transitions>
                                <Panel>
                                    <TextBlock Name="PART_Watermark"
                                               Text="{TemplateBinding Watermark}"
                                               Foreground="{StaticResource ThirdText}"
                                               IsVisible="{TemplateBinding Text, Converter={x:Static StringConverters.IsNullOrEmpty}}"
                                               VerticalAlignment="Center"
                                               HorizontalAlignment="Center"
                                               FontSize="18"
                                               FontWeight="Normal"
                                               LetterSpacing="{TemplateBinding LetterSpacing}"
                                               Opacity="0.7"/>
                                    <ScrollViewer Name="PART_ScrollViewer"
                                                  HorizontalScrollBarVisibility="Hidden"
                                                  VerticalScrollBarVisibility="Hidden">
                                        <TextPresenter Name="PART_TextPresenter"
                                                       Text="{TemplateBinding Text, Mode=TwoWay}"
                                                       CaretIndex="{TemplateBinding CaretIndex}"
                                                       SelectionStart="{TemplateBinding SelectionStart}"
                                                       SelectionEnd="{TemplateBinding SelectionEnd}"
                                                       CaretBrush="{TemplateBinding Foreground}"
                                                       TextWrapping="NoWrap"
                                                       PasswordChar="{TemplateBinding PasswordChar}"
                                                       SelectionBrush="{TemplateBinding SelectionBrush}"
                                                       SelectionForegroundBrush="{TemplateBinding SelectionForegroundBrush}"
                                                       VerticalAlignment="Center"/>
                                    </ScrollViewer>
                                </Panel>
                            </Border>

                            <Border Name="PART_ErrorContainer"
                                    Grid.Row="1"
                                    ClipToBounds="True"
                                    MaxHeight="{TemplateBinding InternalErrorHeight}"
                                    Opacity="{TemplateBinding InternalErrorOpacity}">
                                <Border.Transitions>
                                    <Transitions>
                                        <DoubleTransition Property="MaxHeight" Duration="0:0:0.3" Easing="CubicEaseInOut"/>
                                        <DoubleTransition Property="Opacity" Duration="0:0:0.2" Easing="CubicEaseInOut"/>
                                    </Transitions>
                                </Border.Transitions>

                                <TextBlock Text="{TemplateBinding InternalErrorText}"
                                           Foreground="{TemplateBinding ErrorForeground}"
                                           FontSize="12"
                                           LetterSpacing="0"
                                           Margin="0,6,0,0"
                                           TextAlignment="Center"
                                           TextWrapping="Wrap">
                                </TextBlock>
                            </Border>
                        </Grid>
                    </Border>
                </Grid>
            </ControlTemplate>
        </Setter>
    </Style>

    <Style Selector="controls|AnimatedCodeBox:pointerover,
                   controls|AnimatedCodeBox:focus">
        <Setter Property="Background" Value="{StaticResource FirstPlate}"/>
    </Style>
    
    <Style Selector="controls|AnimatedCodeBox:focus /template/ Border#PART_OuterBorder">
        <Setter Property="RenderTransform" Value="scale(0.98)"/>
    </Style>

    
    <!-- AnimatedButton -->
    <Style Selector="controls|AnimatedButton">
        <Setter Property="Background" Value="{StaticResource FirstElement}"/>
        <Setter Property="FocusAdorner" Value="{x:Null}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="CornerRadius" Value="15"/>
        <Setter Property="Padding" Value="25,15,25,15"/>
        <Setter Property="BackgroundOnHover" Value="{StaticResource SecondElement}"/>
        <Setter Property="RenderTransformOrigin" Value="50%,50%"/>
        <Setter Property="HorizontalContentAlignment" Value="Center"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Transitions">
            <Transitions>
                <DoubleTransition Property="Opacity" Duration="0:0:0.2" Easing="CubicEaseInOut"/>
            </Transitions>
        </Setter>
        <Setter Property="Template">
            <ControlTemplate>
                <!-- Stable Hit-Test Border for Button -->
                <Border Background="Transparent"
                        CornerRadius="{TemplateBinding CornerRadius}">
                    <Border Name="PART_Border" 
                            Background="{TemplateBinding Background}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            CornerRadius="{TemplateBinding CornerRadius}"
                            Padding="{TemplateBinding Padding}"
                            RenderTransform="{TemplateBinding RenderTransform}">
                        <Border.Transitions>
                            <Transitions>
                                <BrushTransition Property="Background" Duration="0:0:0.2"/>
                                <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.1" Easing="CubicEaseOut"/>
                            </Transitions>
                        </Border.Transitions>
                        <ContentPresenter Content="{TemplateBinding DisplayContent}"
                                          HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                          Opacity="{TemplateBinding InternalOpacity}"
                                          RenderTransformOrigin="50%,50%">
                            <ContentPresenter.RenderTransform>
                                <ScaleTransform ScaleX="{Binding InternalOpacity, RelativeSource={RelativeSource TemplatedParent}}" 
                                                ScaleY="{Binding InternalOpacity, RelativeSource={RelativeSource TemplatedParent}}"/>
                            </ContentPresenter.RenderTransform>
                            <ContentPresenter.Transitions>
                                <Transitions>
                                    <DoubleTransition Property="Opacity" Duration="0:0:0.4" Easing="CubicEaseInOut"/>
                                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.2" Easing="BackEaseOut"/>
                                </Transitions>
                            </ContentPresenter.Transitions>
                        </ContentPresenter>
                    </Border>
                </Border>
            </ControlTemplate>
        </Setter>
        <Style Selector="^:pointerover /template/ Border#PART_Border">
            <Setter Property="RenderTransform" Value="scale(0.96)"/>
        </Style>
        <Style Selector="^:pressed /template/ Border#PART_Border">
            <Setter Property="RenderTransform" Value="scale(0.92)"/>
        </Style>
    </Style>
    
    <Style Selector="controls|AnimatedButton:pointerover">
        <Setter Property="Background" Value="{Binding BackgroundOnHover, RelativeSource={RelativeSource Self}}"/>
    </Style>
    
    <!-- Focus indicator (Accessibility) -->
    <Style Selector="controls|AnimatedButton:focus-visible /template/ Border#PART_Border">
        <Setter Property="BorderBrush" Value="{StaticResource ThirdPlate}"/>
    </Style>
    
    <Style Selector="controls|AnimatedButton:pressed">
    </Style>

    <Style Selector="controls|AnimatedButton:disabled">
        <Setter Property="Opacity" Value="0.5"/>
    </Style>
    
    <Design.PreviewWith>
        <Border Padding="100"
                Background="Transparent">
            <controls:AnimatedTextBox/>
        </Border>
    </Design.PreviewWith>
</Styles>
