<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <SolidColorBrush x:Key="FirstPlate" Color="#385F71"/>
    <SolidColorBrush x:Key="SecondPlate" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="ThirdPlate" Color="#9CAFB8"/>
    <SolidColorBrush x:Key="FourPlate" Color="#2C0E37"/>
    <SolidColorBrush x:Key="FirstElement" Color="#4D515B"/>
    <SolidColorBrush x:Key="SecondElement" Color="#9CAFB8"/>
    <SolidColorBrush x:Key="FirstText" Color="#101010"/>
    <SolidColorBrush x:Key="SecondText" Color="#F0F0F0"/>
    <SolidColorBrush x:Key="ThirdText" Color="#4D515B"/>
    <SolidColorBrush x:Key="FourText" Color="#83B5AA"/>
    <SolidColorBrush x:Key="FirstWarning" Color="#FF4F48"/>
    <SolidColorBrush x:Key="SecondWarning" Color="#720E07"/>
</ResourceDictionary>