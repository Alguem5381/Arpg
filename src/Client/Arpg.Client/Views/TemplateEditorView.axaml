<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Arpg.Client.ViewModels"
             x:Class="Arpg.Client.Views.TemplateEditorView"
             x:DataType="vm:TemplateEditorViewModel">
    <Grid RowDefinitions="Auto, *">

        <!-- Cabeçalho -->
        <Border Grid.Row="0" Background="#2D283E" Padding="20" Margin="10" CornerRadius="8"
                BorderBrush="#4A3F6B" BorderThickness="1">
            <StackPanel Spacing="10">
                <Grid ColumnDefinitions="Auto, *, Auto">
                    <Button Grid.Column="0" Content="← Voltar" Background="Transparent"
                            Foreground="#888888" Padding="0,0,15,0" Command="{Binding GoBackCommand}" />
                    <TextBlock Grid.Column="1" Text="Editor de Modelo" FontSize="22"
                               FontWeight="Bold" Foreground="White" VerticalAlignment="Center" />
                    <Button Grid.Column="2" Content="Salvar Alterações" Background="#4A3F6B"
                            Foreground="White" Command="{Binding SaveChangesCommand}" />
                </Grid>
                <TextBox Text="{Binding TemplateName}" PlaceholderText="Nome do Modelo"
                         FontSize="18" FontWeight="Bold" Background="Transparent"
                         BorderThickness="0,0,0,1" />
                <TextBox Text="{Binding TemplateDescription}" PlaceholderText="Descrição..."
                         AcceptsReturn="True" Height="60" TextWrapping="Wrap"
                         Background="Transparent" BorderThickness="0,0,0,1" />
            </StackPanel>
        </Border>

        <!-- Corpo -->
        <ScrollViewer Grid.Row="1" Margin="10">
            <StackPanel Spacing="15">

                <ItemsControl ItemsSource="{Binding Categories}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="vm:TemplateCategoryViewModel">
                            <Border Background="#2A2A2A" CornerRadius="8" Padding="15" Margin="0,0,0,10"
                                    BorderBrush="#3A3A3A" BorderThickness="1">
                                <StackPanel Spacing="10">
                                    <!-- Cabeçalho da Categoria -->
                                    <Grid ColumnDefinitions="Auto, *, Auto, Auto, Auto">
                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding Order, StringFormat='{}{0}. '}"
                                                   FontSize="18" FontWeight="Bold" Foreground="#888888"
                                                   VerticalAlignment="Center" Margin="0,0,6,0" />
                                        <TextBox Grid.Column="1" Text="{Binding Name}"
                                                 PlaceholderText="Nome da Categoria"
                                                 FontSize="16" FontWeight="Bold"
                                                 Background="Transparent" BorderThickness="0"
                                                 Foreground="White" />
                                        <!-- Reordenar categoria -->
                                        <Button Grid.Column="2" Content="↑" Background="Transparent"
                                                Foreground="#888888" Padding="6,2"
                                                Command="{Binding $parent[UserControl].((vm:TemplateEditorViewModel)DataContext).MoveCategoryUpCommand}"
                                                CommandParameter="{Binding}"
                                                ToolTip.Tip="Mover para cima" />
                                        <Button Grid.Column="3" Content="↓" Background="Transparent"
                                                Foreground="#888888" Padding="6,2"
                                                Command="{Binding $parent[UserControl].((vm:TemplateEditorViewModel)DataContext).MoveCategoryDownCommand}"
                                                CommandParameter="{Binding}"
                                                ToolTip.Tip="Mover para baixo" />
                                        <Button Grid.Column="4" Content="✕"
                                                Background="Transparent" Foreground="#FF5555"
                                                Padding="8,4" Command="{Binding DeleteCommand}"
                                                ToolTip.Tip="Remover categoria" />
                                    </Grid>

                                    <!-- Campos da Categoria -->
                                    <ItemsControl ItemsSource="{Binding Fields}" Margin="20,5,0,5">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate DataType="vm:TemplateFieldViewModel">
                                                <Border Background="#333333" CornerRadius="5"
                                                        Padding="10" Margin="0,0,0,6">
                                                    <Grid ColumnDefinitions="*, 110, Auto, Auto, Auto, Auto">
                                                        <TextBox Grid.Column="0" Text="{Binding Name}"
                                                                 PlaceholderText="Nome do Campo"
                                                                 Background="Transparent"
                                                                 BorderThickness="0,0,0,1" />
                                                        <TextBox Grid.Column="1" Text="{Binding Type}"
                                                                 Margin="8,0" IsReadOnly="True"
                                                                 ToolTip.Tip="O tipo será editável futuramente." />
                                                        <CheckBox Grid.Column="2"
                                                                  IsChecked="{Binding IsRequired}"
                                                                  Content="Obrig." Margin="6,0" />
                                                        <Button Grid.Column="3" Content="↑"
                                                                Background="Transparent" Foreground="#888888"
                                                                Padding="5,2"
                                                                Command="{Binding $parent[UserControl].((vm:TemplateEditorViewModel)DataContext).MoveFieldUpCommand}"
                                                                CommandParameter="{Binding}"
                                                                ToolTip.Tip="Mover para cima" />
                                                        <Button Grid.Column="4" Content="↓"
                                                                Background="Transparent" Foreground="#888888"
                                                                Padding="5,2"
                                                                Command="{Binding $parent[UserControl].((vm:TemplateEditorViewModel)DataContext).MoveFieldDownCommand}"
                                                                CommandParameter="{Binding}"
                                                                ToolTip.Tip="Mover para baixo" />
                                                        <Button Grid.Column="5" Content="✕"
                                                                Background="Transparent"
                                                                Foreground="#FF5555" Padding="6,2"
                                                                Command="{Binding DeleteCommand}"
                                                                ToolTip.Tip="Remover campo" />
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <!-- Botão Adicionar Campo -->
                                    <Button Content="+ Adicionar Campo"
                                            Background="Transparent" Foreground="#888888"
                                            HorizontalAlignment="Left" Margin="20,0,0,0"
                                            Command="{Binding AddFieldCommand}" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Botão Adicionar Categoria -->
                <Button Content="+ Adicionar Categoria"
                        Command="{Binding $parent[UserControl].((vm:TemplateEditorViewModel)DataContext).AddCategoryCommand}"
                        Background="#2D283E" Foreground="White"
                        HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                        Margin="0,0,0,30" Padding="15" />
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
