<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Arpg.Client.ViewModels"
             xmlns:templateDto="using:Arpg.Contracts.Dto.Template"
             x:Class="Arpg.Client.Views.TemplatesListView"
             x:DataType="vm:TemplatesListViewModel">
    <Grid>
        <WrapPanel>
            <Button Command="{Binding OpenCreateMenuCommand}" Width="220" Height="150" Margin="10" Background="#2D283E" CornerRadius="8" BorderBrush="#4A3F6B" BorderThickness="1">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="+" FontSize="40" HorizontalAlignment="Center" Foreground="#888888"/>
                    <TextBlock Text="Novo Modelo" HorizontalAlignment="Center" Foreground="#888888"/>
                </StackPanel>
            </Button>
            
            <ItemsControl ItemsSource="{Binding Templates}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="templateDto:SimpleTemplateDto">
                        <Button Background="Transparent" Padding="0" Margin="10"
                                Command="{Binding $parent[UserControl].((vm:TemplatesListViewModel)DataContext).OpenTemplateCommand}"
                                CommandParameter="{Binding Id}">
                            <Border Background="#2D283E" CornerRadius="8" Padding="15"
                                    BorderBrush="#4A3F6B" BorderThickness="1" Width="220" Height="150">
                                <Grid>
                                    <StackPanel>
                                        <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="16" Foreground="White" TextTrimming="CharacterEllipsis" />
                                        <TextBlock Text="Modelo de Ficha" FontSize="12" Foreground="#888888" Margin="0,5,0,0" />
                                        <TextBlock Text="{Binding Description}" FontSize="12" Foreground="#AAAAAA" Margin="0,10,0,0" TextWrapping="Wrap" MaxLines="2" TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                    <Button Content="🗑" Background="Transparent" Foreground="#FF5555" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-10,-10,0"
                                            Command="{Binding $parent[UserControl].((vm:TemplatesListViewModel)DataContext).OpenDeleteMenuCommand}" CommandParameter="{Binding Id}" />
                                </Grid>
                            </Border>
                        </Button>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </WrapPanel>

        <!-- Overlay Menu de Criação -->
        <Grid IsVisible="{Binding IsCreateMenuOpen}" Background="#80000000" ZIndex="5">
            <Button Background="Transparent" Command="{Binding CloseCreateMenuCommand}" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" />
            <Border Background="#2D283E" CornerRadius="12" Padding="25" Width="350" HorizontalAlignment="Center" VerticalAlignment="Center"
                    BorderBrush="#4A3F6B" BorderThickness="1" BoxShadow="0 10 30 0 #40000000">
                <StackPanel Spacing="15">
                    <TextBlock Text="Criar Novo Modelo" FontSize="20" FontWeight="Bold" Foreground="White"/>
                    <TextBox Text="{Binding NewTemplateName}" PlaceholderText="Nome do Modelo..." />
                    <Grid ColumnDefinitions="*, 10, *">
                        <Button Grid.Column="0" Content="Cancelar" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Command="{Binding CloseCreateMenuCommand}" />
                        <Button Grid.Column="2" Content="Criar" Background="#4A3F6B" Foreground="White" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Command="{Binding ConfirmCreateCommand}"/>
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Overlay Menu de Deleção -->
        <Grid IsVisible="{Binding IsDeleteMenuOpen}" Background="#80000000" ZIndex="10">
            <Button Background="Transparent" Command="{Binding CloseDeleteMenuCommand}" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" />
            <Border Background="#2D283E" CornerRadius="12" Padding="25" Width="350" HorizontalAlignment="Center" VerticalAlignment="Center"
                    BorderBrush="#FF5555" BorderThickness="1" BoxShadow="0 10 30 0 #40000000">
                <StackPanel Spacing="15">
                    <TextBlock Text="Deletar Modelo" FontSize="20" FontWeight="Bold" Foreground="#FF5555"/>
                    <TextBlock Text="Digite a senha para confirmar a deleção deste modelo:" Foreground="White" TextWrapping="Wrap"/>
                    <TextBox Text="{Binding DeletePassword}" PasswordChar="•" PlaceholderText="Senha..." />
                    <Grid ColumnDefinitions="*, 10, *">
                        <Button Grid.Column="0" Content="Cancelar" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Command="{Binding CloseDeleteMenuCommand}" />
                        <Button Grid.Column="2" Content="Deletar" Background="#FF5555" Foreground="White" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Command="{Binding ConfirmDeleteCommand}"/>
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
